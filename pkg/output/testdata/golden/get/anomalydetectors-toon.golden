[#3]:
  - objectId: vu9U3hXa3q0AAAABACdidWlsdGluOmRhdmlzLmFub21hbHktZGV0ZWN0b3JzAA
    schemaId: "builtin:davis.anomaly-detectors"
    schemaVersion: 1.0.15
    scope: environment
    value:
      analyzer:
        input[#6]{key,value}:
          alertCondition,ABOVE
          threshold,"90"
          slidingWindow,"5"
          violatingSamples,"3"
          dealertingSamples,"5"
          query,"timeseries cpu=avg(cloud.aws.rds.CPUUtilization), interval:1m"
        name: dt.statistics.ui.anomaly_detection.StaticThresholdAnomalyDetectionAnalyzer
      description: Monitors Aurora cluster CPU utilization to detect performance bottlenecks
      enabled: true
      eventTemplate:
        properties[#3]{key,value}:
          event.type,PERFORMANCE_EVENT
          event.name,Aurora cluster high CPU
          event.description,CPU utilization is high
      source: Clouds
      title: Aurora cluster CPU utilization
  - objectId: xw0V4iYb4r1BBBBBAC1idWlsdGluOmRhdmlzLmFub21hbHktZGV0ZWN0b3JzAB
    schemaId: "builtin:davis.anomaly-detectors"
    schemaVersion: 1.0.15
    scope: environment
    value:
      analyzer:
        input[#0]:
        name: dt.statistics.ui.anomaly_detection.AutoAdaptiveAnomalyDetectionAnalyzer
      enabled: true
      eventTemplate:
        properties[#2]{key,value}:
          event.type,AVAILABILITY_EVENT
          event.name,VPC packet drops detected
      source: Clouds
      title: VPC endpoint packet drops
  - objectId: yz1W5jZc5s2CCCCCAD2idWlsdGluOmRhdmlzLmFub21hbHktZGV0ZWN0b3JzAC
    schemaId: "builtin:davis.anomaly-detectors"
    schemaVersion: 1.0.15
    scope: environment
    value:
      analyzer:
        input[#2]{key,value}:
          alertCondition,ABOVE
          threshold,"85"
        name: dt.statistics.ui.anomaly_detection.StaticThresholdAnomalyDetectionAnalyzer
      description: Disabled detector for EC2 CPU monitoring
      enabled: false
      eventTemplate:
        properties[#2]{key,value}:
          event.type,PERFORMANCE_EVENT
          event.name,EC2 high CPU utilization
      source: dtctl
      title: EC2 instance CPU utilization
